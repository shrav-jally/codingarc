class Solution:
    # Function to calculate Fibonacci using tabulation
    def fib(self, n):
        # If n is 0 or 1, return n
        if n <= 1:
            return n

        # Create dp array
        dp = [0] * (n + 1)

        # Initialize base cases
        dp[0] = 0
        dp[1] = 1

        # Fill dp array iteratively
        for i in range(2, n + 1):
            dp[i] = dp[i - 1] + dp[i - 2]

        # Return final answer
        return dp[n]

