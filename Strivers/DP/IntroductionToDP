class Solution:
    def fib(self, n: int) -> int:
        # If n is 0 return 0
        if n == 0:
            return 0
        # If n is 1 return 1
        if n == 1:
            return 1

        # prev2 stores fib(n-2)
        prev2 = 0
        # prev stores fib(n-1)
        prev = 1

        # Loop from 2 to n
        for i in range(2, n + 1):
            # Calculate current fib
            curr = prev + prev2
            # Update prev2
            prev2 = prev
            # Update prev
            prev = curr

        # Return final answer
        return prev

def main():
    s = Solution()
    n = 10
    print(s.fib(n))

if __name__ == "__main__":
    main()
