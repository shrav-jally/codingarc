class Solution:
    # Function to calculate Fibonacci using memoization
    def fib(self, n, dp):
        # If base case return n
        if n <= 1:
            return n

        # If already computed, return stored value
        if dp[n] != -1:
            return dp[n]

        # Otherwise compute and store
        dp[n] = self.fib(n - 1, dp) + self.fib(n - 2, dp)
        return dp[n]

# Driver
if __name__ == "__main__":
    n = 10
    dp = [-1] * (n + 1)
    sol = Solution()
    print(sol.fib(n, dp))

