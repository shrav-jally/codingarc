# brute force

nums = list(map(int, input().split()))

count_0 = 0
count_1 = 0
count_2 = 0

for num in nums:
    if num == 0:
        count_0 += 1
    elif num == 1:
        count_1 += 1
    elif num == 2:
        count_2 += 1

idx = 0

for i in range(count_0):
    nums[idx] = 0
    idx += 1

for i in range(count_1):
    nums[idx] = 1
    idx += 1

for i in range(count_2):
    nums[idx] = 2
    idx += 1

print(nums)
