class Solution:
    def buildArray(self, target, n):
        res = []
        i = 0
        
        for num in range(1, n + 1):
            if i == len(target):
                break
            
            res.append("Push")
            
            if num == target[i]:
                i += 1
            else:
                res.append("Pop")
                
        return res
