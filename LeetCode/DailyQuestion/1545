class Solution:
    def findKthBit(self, n: int, k: int) -> str:
        if n == 1:
            return "0"
        
        mid = 1 << (n - 1)   # 2^(n-1)
        
        if k == mid:
            return "1"
        elif k < mid:
            return self.findKthBit(n - 1, k)
        else:
            # Mirror position
            mirrored_k = mid - (k - mid)
            bit = self.findKthBit(n - 1, mirrored_k)
            # Invert bit
            return "1" if bit == "0" else "0"
