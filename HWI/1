Approach & Complexity

A brute-force approach taking O(n * q) will result in a Time Limit Exceeded (TLE) error given the constraints. 
To optimize this to O(N + Q log N), we use a Segment Tree with Lazy Propagation. 

When a Type 1 query updates a range [l, r], it replaces the values with an arithmetic progression (AP): A[l], 2 * A[l], 3 * A[l] ...
The lazy tag at each node will store the starting index of the AP and the multiplier A[l]. When pushing updates down or querying, 
we can calculate the sum of the AP in O(1) time for any segment using the sum of an arithmetic sequence formula.

Time Complexity: O(N) to build, O(log N) per query -> Total: O(N + Q log N)
Space Complexity: O(N) for the Segment Tree arrays.


Python 3 Solution

import sys

sys.setrecursionlimit(300000)

def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    A = [int(x) for x in input_data[1:n+1]]
    q = int(input_data[n+1])
    
    MOD = 10**9 + 7
    
    tree = [0] * (4 * n)
    lazy = [None] * (4 * n)
    
    def build(node, start, end):
        if start == end:
            tree[node] = A[start] % MOD
            return
        mid = (start + end) // 2
        build(2 * node, start, mid)
        build(2 * node + 1, mid + 1, end)
        tree[node] = (tree[2 * node] + tree[2 * node + 1]) % MOD
        
    def apply_lazy(node, start, end, L, val):
        lazy[node] = (L, val)
        length = end - start + 1
        first = (start - L + 1) * val
        last = (end - L + 1) * val
        tree[node] = (length * (first + last) // 2) % MOD
        
    def push(node, start, end):
        if lazy[node] is not None:
            L, val = lazy[node]
            mid = (start + end) // 2
            apply_lazy(2 * node, start, mid, L, val)
            apply_lazy(2 * node + 1, mid + 1, end, L, val)
            lazy[node] = None
            
    def update(node, start, end, l, r, L, val):
        if start > r or end < l:
            return
        if start >= l and end <= r:
            apply_lazy(node, start, end, L, val)
            return
        push(node, start, end)
        mid = (start + end) // 2
        update(2 * node, start, mid, l, r, L, val)
        update(2 * node + 1, mid + 1, end, l, r, L, val)
        tree[node] = (tree[2 * node] + tree[2 * node + 1]) % MOD
        
    def query(node, start, end, l, r):
        if start > r or end < l:
            return 0
        if start >= l and end <= r:
            return tree[node]
        push(node, start, end)
        mid = (start + end) // 2
        p1 = query(2 * node, start, mid, l, r)
        p2 = query(2 * node + 1, mid + 1, end, l, r)
        return (p1 + p2) % MOD

    build(1, 0, n - 1)
    
    idx = n + 2
    total_sum = 0
    
    for _ in range(q):
        type_q = int(input_data[idx])
        l = int(input_data[idx+1])
        r = int(input_data[idx+2])
        idx += 3
        
        if type_q == 1:
            val = query(1, 0, n - 1, l, l)
            update(1, 0, n - 1, l, r, l, val)
        else:
            total_sum = (total_sum + query(1, 0, n - 1, l, r)) % MOD
            
    print(total_sum)

if __name__ == '__main__':
    solve()


